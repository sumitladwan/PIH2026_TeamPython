# HackShield Portal Environment Variables
# Copy this file to .env.local and fill in your values

# MongoDB Atlas Connection String
# Get yours at: https://cloud.mongodb.com → Cluster → Connect → Drivers → Node.js
# Replace YOUR_USER and YOUR_PASSWORD with real values (no angle brackets!)
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.dn2zkl5.mongodb.net/hackshield?retryWrites=true&w=majority&appName=Cluster0

# NextAuth Configuration
# Local Development: http://localhost:3000
# Railway Production: https://your-railway-app-name.up.railway.app
NEXTAUTH_URL=https://pih2026teampython-production.up.railway.app
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production

# JWT Secret
JWT_SECRET=hackshield-jwt-secret-key-2024

# Socket.io Server Port
SOCKET_PORT=3001

# Optional: Email Configuration (SendGrid)
# SENDGRID_API_KEY=your-sendgrid-api-key
# EMAIL_FROM=noreply@hackshield.com

# Optional: Stripe Configuration
# STRIPE_PUBLIC_KEY=your-stripe-public-key
# STRIPE_SECRET_KEY=your-stripe-secret-key

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: GitHub OAuth
# GITHUB_ID=your-github-id
# GITHUB_SECRET=your-github-secret
